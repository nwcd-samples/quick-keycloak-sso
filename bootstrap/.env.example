# Keycloak 连接
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_MASTER_ADMIN_USERNAME=admin
KEYCLOAK_MASTER_ADMIN_PASSWORD=changeme

# Realm（默认 quick）
KEYCLOAK_QUICK_REALM=quick

# Quick 管理员用户
KEYCLOAK_QUICK_ADMIN_USERNAME=admin
KEYCLOAK_QUICK_ADMIN_PASSWORD=changeme
KEYCLOAK_QUICK_ADMIN_EMAIL=admin@example.com

# Amazon Quick 账户名称
QUICK_ACCOUNT_NAME=example

# AWS 账户
AWS_ACCOUNT_ID=123456789012

# SAML Mapper 配置
MAPPER_SESSION_DURATION_VALUE=43200
